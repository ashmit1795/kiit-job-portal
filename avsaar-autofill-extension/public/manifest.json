{
  "manifest_version": 3,
  "name": "Avsaar Autofill Assistant",
  "version": "1.0.0",
  "description": "Smart, college-placement autofill companion. Save your details once and instantly fill university Google Forms.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://docs.google.com/forms/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/forms/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
